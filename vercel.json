{
  "version": 2,
  "buildCommand": "bash vercel_build.sh",
  "builds": [
    {
      "src": "estate_project/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "estate/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/estate/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "estate_project/wsgi.py"
    }
  ]
}
