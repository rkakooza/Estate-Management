{
  "version": 2,
  "buildCommand": "bash vercel_build.sh",
  "builds": [
    {
      "src": "estate_project/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "vercel_build.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "estate_project/wsgi.py"
    }
  ]
}
