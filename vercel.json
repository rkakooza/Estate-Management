{
  "version": 2,
  "buildCommand": "bash vercel_build.sh",
  "functions": {
    "estate_project/wsgi.py": {
      "includeFiles": "staticfiles/**"
    }
  },
  "builds": [
    {
      "src": "estate_project/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "estate_project/wsgi.py"
    }
  ]
}
